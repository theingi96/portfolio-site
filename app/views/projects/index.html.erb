<section class="projects-page">

  <div class="projects-title">
    <h1>制作実績</h1>
    <p>TECH CAMPおよび個人開発で制作したWebアプリケーション</p>
  </div>

  <div class="projects-grid">

    <% @projects.each do |project| %>

      <% github_url =
        case project.title
        when "FURIMA"
          "https://github.com/theingi96/furima-46495"
        when "Portfolio Site"
          "https://github.com/theingi96/portfolio-site"
        else
          project.github_url
        end
      %>

      <div class="project-card">

        <div class="project-image">

          <% if project.title == "FURIMA" %>

            <%= image_tag "furima.png", alt: "FURIMA" %>

          <% elsif project.title == "Portfolio Site" %>

            <%= image_tag "portfolio.png", alt: "Portfolio Site" %>

          <% else %>

            <%= image_tag "portfolio.png", alt: project.title %>

          <% end %>

        </div>

        <div class="project-body">

          <% if project.title == "FURIMA" %>
            <span class="project-status featured">⭐ Featured Project</span>
          <% elsif project.title == "Portfolio Site" %>
            <span class="project-status current">🚀 Current Project</span>
          <% end %>

          <h2><%= project.title %></h2>

          <p class="project-description">
            <%= project.description %>
          </p>

          <% if project.title == "FURIMA" %>

            <div class="project-tags">
              <span>Ruby</span>
              <span>Ruby on Rails</span>
              <span>JavaScript</span>
              <span>MySQL</span>
              <span>HTML</span>
              <span>CSS</span>
              <span>Git</span>
              <span>GitHub</span>
            </div>

          <% elsif project.title == "Portfolio Site" %>

            <div class="project-tags">
              <span>Ruby on Rails</span>
              <span>HTML</span>
              <span>CSS</span>
              <span>JavaScript</span>
              <span>GitHub</span>
            </div>

          <% end %>

          <div class="project-links">

            <a href="<%= github_url %>" target="_blank" rel="noopener noreferrer">
              <i class="fa-brands fa-github"></i>
              GitHub
            </a>

            <% if project.title == "FURIMA" %>

              <a href="https://furima-46495.onrender.com" target="_blank" rel="noopener noreferrer">
                Demo
              </a>

            <% elsif project.app_url.present? %>

              <a href="<%= project.app_url %>" target="_blank" rel="noopener noreferrer">
                Demo
              </a>

            <% end %>

          </div>

        </div>

      </div>

    <% end %>

  </div>

</section>