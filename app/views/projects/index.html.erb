<section class="projects-section" id="projects">
  <h2>Projects</h2>

  <% @projects.each do |project| %>
    <div class="project-card">
      <h3><%= project.title %></h3>

      <p>
        <%= project.description %>
      </p>

      <p>
        GitHub:
        <%= project.github_url %>
      </p>

      <p>
        App:
        <%= project.app_url %>
      </p>
    </div>
  <% end %>
</section>
